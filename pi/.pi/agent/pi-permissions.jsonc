{
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "deny",
    "skills": "allow",
    "special": "ask"
  },
  "tools": {
    "read": "allow", "ls": "allow",
    "grep": "allow",
    "find": "allow",
    "write": "allow",
    "edit": "allow"
  },
  "bash": {
    "*": "ask",
    "rm *": "deny",
    "ls *": "allow",
    "tree *": "allow",
    "grep *": "allow",
    "rg *": "allow",
    "find *": "allow",
    "cat *": "allow",
    "head *": "allow",
    "tail *": "allow",
    "git status *": "allow",
    "git diff *": "allow",
    "git log *": "allow",
    "git show *": "allow",
    "git add *": "ask",
    "git commit *": "ask",
    "git push *": "deny",
    "git pull *": "deny",
    "uv *": "ask",
    "uv run ruff *": "allow",
    "uv run ty *": "allow",
    "uv run pytest *": "allow",
    "cargo *": "ask",
    "cargo check *": "allow",
    "cargo fmt *": "allow",
    "cargo +nightly fmt *": "allow",
    "cargo clippy *": "allow",
    "cargo +nightly clippy *": "allow",
    "cargo test *": "allow",
    "tofu *": "ask",
    "tofu plan *": "allow",
    "tofu fmt *": "allow",
    "tofu validate *": "allow",
    "tofu plan *": "deny",
    "docker *": "deny",
    "just *": "ask",
    "just check *": "allow",
    "just check-*": "allow",
    "just test *": "allow"
  }
}
